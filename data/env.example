# ESPN Fantasy Basketball Credentials
# -----------------------------------
# Find these by logging into ESPN Fantasy in Chrome:
# DevTools (F12) -> Application -> Cookies -> espn.com
#
# SWID looks like: {XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX}
# ESPN_S2 is a long base64 string
# League ID is in your league URL: fantasy.espn.com/basketball/league?leagueId=XXXXXX

ESPN_LEAGUE_ID=
ESPN_S2=
ESPN_SWID=

# ESPN uses the ENDING year of the season (2025-26 season = 2026)
ESPN_YEAR=2026
